{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Curriculum",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generate-course/generateCurriculum.ts",
            "args": [
                "--provider", "gemini",
                "--course",   "${input:courseTitle}",
                "--input",    "${workspaceFolder}/tools/generate-course/input/lesson.txt",
                "--output",   "${workspaceFolder}/tools/generate-course/output/lesson.json"
            ],
            "cwd": "${workspaceFolder}/tools/generate-course",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Course Content",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generate-course/generateCourseContent.ts",
            "args": [
                "--curriculum-id", "6a04c6a3350b1020372dbf69",
                "--chapters", "The V8 Engine & Optimization Pipeline",
                "--lessons", "${input:lessonFilter}"
            ],
            "cwd": "${workspaceFolder}/tools/generate-course",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },

        {
            "type": "node",
            "request": "launch",
            "name": "Generate Lesson (OpenAI)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generate-lesson/generateMock.ts",
            "cwd": "${workspaceFolder}/tools/generate-lesson",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development",
                "DEFAULT_PROVIDER": "openai"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Lesson (Gemini)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generate-lesson/generateMock.ts",
            "cwd": "${workspaceFolder}/tools/generate-lesson",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development",
                "DEFAULT_PROVIDER": "gemini"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Glossary",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generate-glossary/generateGlossary.ts",
            "cwd": "${workspaceFolder}/tools/generate-glossary",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Setup DB",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/setup-db/setupDb.ts",
            "cwd": "${workspaceFolder}/tools/setup-db",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Next.js: Server",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Local:.+(https?://[^\\s]+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Next.js: Chrome",
            "url": "http://localhost:6969",
            "webRoot": "${workspaceFolder}",
            "sourceMapPathOverrides": {
                "webpack://_N_E/*": "${webRoot}/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Server + Chrome",
            "configurations": [
                "Next.js: Server",
                "Next.js: Chrome"
            ],
            "stopAll": true,
            "preLaunchTask": null
        }
    ],
    "inputs": [
        {
            "id": "courseTitle",
            "type": "promptString",
            "description": "Enter the Course Title",
            "default": "My Course"
        },
        {
            "id": "curriculumId",
            "type": "promptString",
            "description": "Enter the curriculum ID"
        },
        {
            "id": "chapterFilter",
            "type": "promptString",
            "description": "Chapters to generate (comma separated names/slugs)",
            "default": "all"
        },
        {
            "id": "lessonFilter",
            "type": "promptString",
            "description": "Lessons to generate (comma separated names/slugs)",
            "default": "all"
        }
    ]
}
