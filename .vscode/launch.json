{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Course (Old)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/tools/content/generateCourse.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "outputCapture": "std"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Course (AI)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generators/generateCourse.ts",
            "args": [
                "example.json"
            ],
            "cwd": "${workspaceFolder}/tools/generators",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Generate Lesson (AI)",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx"
            ],
            "program": "${workspaceFolder}/tools/generator-lesson/generateLesson.ts",
            "args": [
                "SSRF, open redirects, request smuggling (concepts)"
            ],
            "cwd": "${workspaceFolder}/tools/generator-lesson",
            "console": "integratedTerminal",
            "outputCapture": "std",
            "env": {
                "NODE_ENV": "development"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Next.js: Server",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Local:.+(https?://[^\\s]+)",
                "uriFormat": "%s",
                "action": "debugWithChrome"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Next.js: Chrome",
            "url": "http://localhost:6969",
            "webRoot": "${workspaceFolder}",
            "sourceMapPathOverrides": {
                "webpack://_N_E/*": "${webRoot}/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Server + Chrome",
            "configurations": [
                "Next.js: Server",
                "Next.js: Chrome"
            ],
            "stopAll": true,
            "preLaunchTask": null
        }
    ]
}
